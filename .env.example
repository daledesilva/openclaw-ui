# Copy to `.env.local` on your development machine (gitignored).
# Point at the LAN IP (or hostname) of the computer running OpenClaw.
#
# On the OpenClaw machine: do not set this when you run `npm run build`, so the
# built app uses the same host as the page (localhost or that machine’s IP).

VITE_OPENCLAW_GATEWAY_URL=ws://192.168.X.Y:Z

# Optional: gateway auth token (OPENCLAW_GATEWAY_TOKEN or --token). Required if the
# gateway enforces auth. Exposed in client bundle; acceptable for LAN/dev.
# VITE_OPENCLAW_GATEWAY_TOKEN=

# Optional: session key. If unset, the UI uses the gateway hello snapshot
# `sessionDefaults.mainSessionKey` (often `agent:main:main`) when available, else `main`.
# VITE_OPENCLAW_SESSION_KEY=agent:main:main

# Optional: set to 1 for verbose gateway frame logging (full JSON dumps).
# VITE_OPENCLAW_DEBUG=1

# Optional: override the +build metadata segment (SemVer). CI sets this from the
# workflow run number. Omit locally to use auto-increment `.openclaw-build-rev`.
# VITE_BUILD_REV=

# --- Host-only: GitHub Actions deploy webhook (not Vite; not committed) ---
# Copy these lines to `.env.webhook` in the repo root on the OpenClaw machine
# (see README). Generate a long random secret; use the same value for the
# GitHub repo secret `DEPLOY_WEBHOOK_SECRET`.
#
# DEPLOY_WEBHOOK_SECRET=
# WEBHOOK_LISTEN_HOST=127.0.0.1
# WEBHOOK_LISTEN_PORT=8788
# WEBHOOK_ENV_FILE=   optional: absolute path to an env file instead of .env.webhook
